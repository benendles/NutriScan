<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/charcoal">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginTop="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_back_btn"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Scan Food"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="@font/syne_bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● LIVE"
            android:textColor="@color/rust_light"
            android:textSize="11sp"
            android:fontFamily="@font/dm_mono"/>

    </LinearLayout>

    <!-- Camera Preview -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="8dp">

        <androidx.camera.view.PreviewView
            android:id="@+id/camera_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/charcoal_soft"/>

        <!-- Scan frame overlay -->
        <com.nutriscan.app.ui.scan.ScanOverlayView
            android:id="@+id/scan_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="Position food within the frame"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/dm_mono"/>

    </FrameLayout>

    <!-- Mode Toggle + Capture -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/mode_toggle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_mode_toggle"
            android:orientation="horizontal"
            android:padding="4dp">

            <TextView
                android:id="@+id/btn_mode_photo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📸 Photo"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:fontFamily="@font/dm_mono"
                android:gravity="center"
                android:background="@drawable/bg_mode_active"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btn_mode_gallery"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🎞 Gallery"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/dm_mono"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btn_mode_manual"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="✍ Manual"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/dm_mono"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/btn_capture"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:clickable="true"
            android:focusable="true">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_capture_outer"/>

            <View
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_capture_inner"/>

        </FrameLayout>

    </LinearLayout>

    <!-- Result Panel (hidden initially) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/result_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_result_panel"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_drag_handle"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DETECTED FOODS"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="@font/dm_mono"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_detected_foods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Totals row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_total_row"
                android:padding="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TOTAL" android:textColor="@color/text_muted" android:textSize="11sp" android:fontFamily="@font/dm_mono" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/tv_total_kcal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="541 kcal" android:textColor="@color/text_primary" android:textSize="22sp" android:fontFamily="@font/syne_bold"/>
                </LinearLayout>

                <TextView android:id="@+id/tv_total_macros" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="P: 48g  C: 52g  F: 14g" android:textColor="@color/text_muted" android:textSize="11sp" android:fontFamily="@font/dm_mono"/>

            </LinearLayout>

            <Button
                android:id="@+id/btn_confirm_scan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Save to Log ✓"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/syne_bold"
                android:background="@drawable/bg_button_olive"
                android:stateListAnimator="@null"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
