<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card_cream"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tv_food_emoji"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="🍚"
        android:textSize="24sp"
        android:gravity="center"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_food_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rice &amp; Chicken"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="@font/syne_bold"/>

        <TextView
            android:id="@+id/tv_food_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:45 · LUNCH · 350g"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="@font/dm_mono"
            android:layout_marginTop="2dp"/>

        <ProgressBar
            android:id="@+id/progress_food"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:progressDrawable="@drawable/progress_food_bar"
            android:progress="75"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_food_kcal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="738"
        android:textColor="@color/olive"
        android:textSize="14sp"
        android:fontFamily="@font/dm_mono"
        android:textStyle="bold"
        android:layout_marginStart="12dp"/>

</LinearLayout>
