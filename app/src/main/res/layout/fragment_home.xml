<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HERO SECTION (dark) -->
        <LinearLayout
            android:id="@+id/hero_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/charcoal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="40dp">

            <!-- Greeting Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_greeting_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good morning"
                        android:textColor="@color/olive_pale"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_mono"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tv_greeting_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alex 👋"
                        android:textColor="@color/white_soft"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/syne_bold"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_avatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="A"
                    android:textColor="@color/olive_pale"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_avatar"/>

            </LinearLayout>

            <!-- Calorie Ring -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp">

                <com.nutriscan.app.ui.home.CalorieRingView
                    android:id="@+id/calorie_ring"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_calories_consumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,247"
                        android:textColor="@color/white_soft"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/syne_bold"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="of 2,000 kcal"
                        android:textColor="#668A8A7A"
                        android:textSize="11sp"
                        android:fontFamily="@font/dm_mono"
                        android:gravity="center"/>

                </LinearLayout>

            </FrameLayout>

            <!-- Macro Pills -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <include layout="@layout/item_macro_pill"
                    android:id="@+id/macro_protein"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"/>

                <include layout="@layout/item_macro_pill"
                    android:id="@+id/macro_carbs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"/>

                <include layout="@layout/item_macro_pill"
                    android:id="@+id/macro_fats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"/>

                <include layout="@layout/item_macro_pill"
                    android:id="@+id/macro_water"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>

            </LinearLayout>

        </LinearLayout>

        <!-- BODY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Add Food Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Add Food"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/syne_bold"/>

            </LinearLayout>

            <!-- Action Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_scan"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/olive"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:text="📸"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_wrap"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scan Food"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:fontFamily="@font/syne_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="POINT &amp; DETECT"
                            android:textColor="#99FFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="@font/dm_mono"
                            android:letterSpacing="0.08"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_voice"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/rust"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:text="🎤"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_wrap"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Voice Log"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:fontFamily="@font/syne_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JUST SPEAK"
                            android:textColor="#99FFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="@font/dm_mono"
                            android:letterSpacing="0.08"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Today's Log Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Today's Log"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/syne_bold"/>

                <TextView
                    android:id="@+id/tv_see_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all →"
                    android:textColor="@color/olive_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/dm_mono"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- Food Log RecyclerView (preview - 3 items) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_food_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- AI Insights Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AI Insights"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/syne_bold"/>

                <TextView
                    android:id="@+id/tv_view_all_ai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all →"
                    android:textColor="@color/olive_light"
                    android:textSize="12sp"
                    android:fontFamily="@font/dm_mono"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- Suggestion Cards -->
            <include layout="@layout/item_suggestion_card" android:id="@+id/suggestion_calories"/>
            <include layout="@layout/item_suggestion_card" android:id="@+id/suggestion_water"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
