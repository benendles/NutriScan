<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/cream">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp" android:paddingBottom="0dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Food Log" android:textColor="@color/text_primary" android:textSize="26sp" android:fontFamily="@font/syne_bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="TODAY" android:textColor="@color/text_muted" android:textSize="12sp"
            android:fontFamily="@font/dm_mono" android:letterSpacing="0.1" android:layout_marginTop="4dp" android:layout_marginBottom="20dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card_charcoal" android:padding="16dp"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TOTAL TODAY" android:textColor="@color/olive_pale" android:textSize="11sp" android:fontFamily="@font/dm_mono" android:letterSpacing="0.1"/>
                <TextView android:id="@+id/tv_total_calories" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1,247" android:textColor="@color/white" android:textSize="28sp" android:fontFamily="@font/syne_bold"/>
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="end">
                <TextView android:id="@+id/tv_total_goal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Goal: 2,000" android:textColor="@color/olive_pale" android:textSize="11sp" android:fontFamily="@font/dm_mono" android:layout_marginBottom="6dp"/>
                <ProgressBar android:id="@+id/progress_day_calories" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="80dp" android:layout_height="6dp" android:progressDrawable="@drawable/progress_food_bar" android:progress="62"/>
                <TextView android:id="@+id/tv_progress_percent" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="62% of goal" android:textColor="@color/olive_pale" android:textSize="11sp" android:fontFamily="@font/dm_mono" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_log_foods"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="8dp"
        android:clipToPadding="false"/>
</LinearLayout>
