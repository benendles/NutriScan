<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/charcoal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginTop="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_back_btn"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Log"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="@font/syne_bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WHAT DID YOU EAT?"
            android:textColor="@color/olive_pale"
            android:textSize="12sp"
            android:fontFamily="@font/dm_mono"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_voice_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to speak"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:fontFamily="@font/syne_bold"
            android:layout_marginBottom="40dp" />

        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_mic_outer" />

            <FrameLayout
                android:id="@+id/btn_mic"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_mic_btn"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🎙️"
                    android:textSize="38sp" />
            </FrameLayout>
        </FrameLayout>

        <com.nutriscan.app.ui.voice.WaveformView
            android:id="@+id/waveform_view"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:visibility="invisible"
            android:layout_marginVertical="16dp" />

        <TextView
            android:id="@+id/tv_transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I had rice and chicken for lunch..."
            android:textColor="#66FDFAF5"
            android:textSize="16sp"
            android:gravity="center"
            android:background="@drawable/bg_transcript"
            android:padding="18dp"
            android:lineSpacingMultiplier="1.4" />

        <LinearLayout
            android:id="@+id/parsed_foods_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DETECTED"
                android:textColor="@color/olive_pale"
                android:textSize="11sp"
                android:fontFamily="@font/dm_mono"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tv_parsed_food1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_parsed_item"
                android:padding="14dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="@font/dm_mono"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_parsed_food2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_parsed_item"
                android:padding="14dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="@font/dm_mono" />

            <Button
                android:id="@+id/btn_confirm_voice"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Save to Log ✓"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/syne_bold"
                android:background="@drawable/bg_button_olive"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
