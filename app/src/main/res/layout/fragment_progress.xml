<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/cream">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="24dp" android:paddingBottom="0dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Progress" android:textColor="@color/text_primary" android:textSize="26sp" android:fontFamily="@font/syne_bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WEIGHT &amp; GOALS TRACKER" android:textColor="@color/text_muted"
                android:textSize="12sp" android:fontFamily="@font/dm_mono" android:letterSpacing="0.08" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Weight Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card_charcoal" android:layout_margin="20dp" android:padding="24dp" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CURRENT WEIGHT" android:textColor="@color/olive_pale" android:textSize="11sp"
                android:fontFamily="@font/dm_mono" android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tv_current_weight" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="72.4" android:textColor="@color/white" android:textSize="48sp" android:fontFamily="@font/syne_bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" kg" android:textColor="@color/olive_pale" android:textSize="18sp" android:fontFamily="@font/dm_mono"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                <TextView android:id="@+id/tv_weight_change" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="↓ 0.6 kg" android:textColor="@color/olive_mid" android:textSize="13sp"
                    android:fontFamily="@font/dm_mono" android:background="@drawable/bg_pill_olive_dim" android:padding="6dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="START 78kg" android:textColor="@color/olive_pale" android:textSize="11sp" android:fontFamily="@font/dm_mono"/>
                <ProgressBar android:id="@+id/progress_weight_goal" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                    android:layout_marginHorizontal="10dp" android:progressDrawable="@drawable/progress_food_bar" android:progress="68"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GOAL 68kg" android:textColor="@color/olive_pale" android:textSize="11sp" android:fontFamily="@font/dm_mono"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Chart -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card_cream" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginBottom="20dp" android:padding="20dp" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WEIGHT THIS MONTH (KG)" android:textColor="@color/text_muted"
                android:textSize="11sp" android:fontFamily="@font/dm_mono" android:letterSpacing="0.1" android:layout_marginBottom="16dp"/>
            <com.github.mikephil.charting.charts.LineChart android:id="@+id/weight_chart"
                android:layout_width="match_parent" android:layout_height="200dp"/>
        </LinearLayout>

        <!-- Weight Input -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card_olive" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginBottom="20dp"
            android:padding="20dp" android:orientation="horizontal" android:gravity="center_vertical">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="LOG TODAY'S WEIGHT" android:textColor="@color/olive_pale"
                    android:textSize="11sp" android:fontFamily="@font/dm_mono" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/et_weight_input" android:layout_width="match_parent" android:layout_height="52dp"
                    android:background="@drawable/bg_weight_input" android:padding="14dp" android:hint="72.4"
                    android:textColorHint="#66FFFFFF" android:textColor="@color/white" android:textSize="20sp"
                    android:fontFamily="@font/syne_bold" android:inputType="numberDecimal"/>
            </LinearLayout>
            <Button android:id="@+id/btn_save_weight" android:layout_width="52dp" android:layout_height="52dp"
                android:layout_marginStart="16dp" android:text="✓" android:textColor="@color/white"
                android:textSize="20sp" android:background="@drawable/bg_save_weight_btn" android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- Stats Grid -->
        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="2" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginBottom="24dp"
            android:useDefaultMargins="true">
            <include layout="@layout/item_stat_card" android:id="@+id/stat_bmi" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1"/>
            <include layout="@layout/item_stat_card" android:id="@+id/stat_lost" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1"/>
            <include layout="@layout/item_stat_card" android:id="@+id/stat_to_goal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1"/>
            <include layout="@layout/item_stat_card" android:id="@+id/stat_avg" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1"/>
        </GridLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
