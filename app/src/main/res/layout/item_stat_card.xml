<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/bg_card_cream" android:padding="16dp">
    <TextView android:id="@+id/tv_stat_label" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="BMI" android:textColor="@color/text_muted" android:textSize="11sp"
        android:fontFamily="@font/dm_mono" android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/tv_stat_value" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="22.8" android:textColor="@color/text_primary" android:textSize="24sp" android:fontFamily="@font/syne_bold"/>
</LinearLayout>
